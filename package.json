{
  "name": "openextract",
  "version": "0.4.0",
  "description": "Free, open-source iPhone backup extractor",
  "main": "dist-electron/main.js",
  "author": "OpenExtract Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json && wait-on http://127.0.0.1:5179 && electron .\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "python:install": "node scripts/venv-bin.js pip install -r python/requirements.txt",
    "python:install:dev": "node scripts/venv-bin.js pip install -r python/requirements-dev.txt",
    "python:lint": "node scripts/venv-bin.js ruff check python/",
    "python:test": "node scripts/venv-bin.js pytest python/tests/ -v",
    "python:bundle": "cd python && pyinstaller --onefile --name openextract-engine main.py",
    "setup": "node scripts/setup.js",
    "test:fixtures": "node scripts/venv-bin.js python tests/fixtures/build_fixture.py",
    "pretest:e2e": "npm run build",
    "pretest:e2e:ci": "npm run build",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:fast": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ci": "OPENEXTRACT_E2E_NO_SANDBOX=1 xvfb-run -a playwright test --config tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "benz-amr-recorder": "^1.1.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.1.0",
    "electron-builder": "^26.0.12",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openextract.app",
    "productName": "OpenExtract",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*.js",
      "python/dist/**/*"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "afterSign": "build/notarize.js",
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "extraResources": [
        {
          "from": "python/dist/openextract-engine",
          "to": "python/openextract-engine"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "azureSignOptions": {
        "publisherName": "Charles West",
        "endpoint": "https://eus.codesigning.azure.net/",
        "certificateProfileName": "openextract",
        "codeSigningAccountName": "openextract-signing"
      },
      "extraResources": [
        {
          "from": "python/dist/openextract-engine.exe",
          "to": "python/openextract-engine.exe"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "extraResources": [
        {
          "from": "python/dist/openextract-engine",
          "to": "python/openextract-engine"
        }
      ]
    }
  }
}
